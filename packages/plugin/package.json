{
  "name": "@halt/plugin",
  "version": "2.4.0",
  "description": "Halt plugin for OpenClaw — agent monitoring, alerting, and kill switch",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "README.md",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "halt",
    "openclaw",
    "openclaw-plugin",
    "agent-monitoring",
    "ai-safety",
    "kill-switch",
    "anomaly-detection",
    "observability"
  ],
  "author": "David Kogan <david@halt.dev>",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidkny22/halt.git"
  },
  "homepage": "https://halt.dev",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@halt/shared": "workspace:^",
    "@halt/cli": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
