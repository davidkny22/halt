{
  "id": "clawnitor",
  "name": "Clawnitor",
  "description": "Agent monitoring and safety layer — real-time event capture, alerting, and kill switch for OpenClaw agents",
  "configSchema": {
    "type": "object",
    "required": ["apiKey"],
    "properties": {
      "apiKey": { "type": "string" },
      "backendUrl": { "type": "string", "default": "https://api.clawnitor.io" },
      "spendLimit": { "type": "number", "default": 100 },
      "rateLimit": { "type": "number", "default": 120 },
      "toolBlocklist": { "type": "array", "items": { "type": "string" }, "default": [] },
      "redactionPatterns": { "type": "array", "items": { "type": "string" }, "default": [] }
    }
  },
  "uiHints": {
    "apiKey": { "label": "Clawnitor API Key", "sensitive": true, "placeholder": "clw_live_..." },
    "backendUrl": { "label": "Backend URL", "placeholder": "https://api.clawnitor.io" },
    "spendLimit": { "label": "Spend Limit ($/session)", "placeholder": "100" },
    "rateLimit": { "label": "Rate Limit (calls/min)", "placeholder": "120" }
  }
}
