{
  "name": "@halt/shared",
  "version": "1.2.1",
  "description": "Shared types, schemas, and constants for Halt — agent monitoring for OpenClaw",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "halt",
    "openclaw",
    "agent-monitoring",
    "ai-safety",
    "kill-switch"
  ],
  "author": "David Kogan <david@halt.dev>",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidkny22/halt.git",
    "directory": "packages/shared"
  },
  "homepage": "https://halt.dev",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "^3.24",
    "uuidv7": "^1"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
